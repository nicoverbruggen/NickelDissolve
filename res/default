#
# NickelDissolve configuration   (changes take effect on reboot)
#
# Kindle-style directional page-turn "band wipe": the new page sweeps in strip-by-strip instead
# of a single flat refresh. Kobo-agnostic — works on the hwtcon (MTK: Clara BW/Colour, Libra
# Colour) and mxcfb (i.MX) update paths by reusing the turn's own e-ink update, chopped into
# swept partial strips.
#
# ── SAFETY ──────────────────────────────────────────────────────────────────────────────
# Default mode is "observe": nothing changes, it just logs the e-ink ioctl stream. Set
# nds_mode:sweep to enable. Only the full-screen update right after a page turn is ever
# touched. Revert with nds_mode:observe (or delete `uninstall`).

nds_enabled:1

# "observe" = passthrough + log (safe default). "sweep" = do the band-wipe on page turns.
nds_mode:observe

# Number of vertical strips (2–32). More = smoother + slower.
nds_strips:8

# Per-strip waveform. 0 = KEEP the turn's own waveform (recommended, platform-agnostic — this is
# what preserves colour/CFA pages and "just works" on any device). A non-zero value forces a raw
# waveform id, which is PLATFORM-SPECIFIC: on hwtcon 1=DU 3=GL16 4=GLR16 6=A2; on mxcfb the ids
# differ (e.g. REAGL=6). Leave 0 unless you know your device.
nds_strip_waveform:0

# Forward-turn sweep direction ("rtl" like the Kindle, or "ltr"). Back turns flip automatically.
nds_direction:rtl

# Between strips: "submission" (fast; on hwtcon this beats the driver's update merge) or
# "complete" (slower, more discrete steps). On mxcfb there's no submission wait, so this is
# "complete" or nothing.
nds_wait:submission

# Extra pause between strips, microseconds (0–50000). The animation-speed dial — raise to slow it.
nds_delay_us:0

# Log the e-ink ioctl stream / sweep events. Set 0 to quieten.
nds_log_ioctl:1
